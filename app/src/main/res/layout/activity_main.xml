<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0B3D0B"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Título principal -->
    <TextView
        android:id="@+id/txtTitulo"
        android:text="Detector de Plagas"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#A8E6A1"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Botón de cámara -->
    <Button
        android:id="@+id/btnCamara"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="📷 Abrir Cámara"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        android:layout_marginTop="8dp"
        android:elevation="6dp" />

    <!-- Botón de galería -->
    <Button
        android:id="@+id/btnGaleria"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="🖼️ Abrir Galería"
        android:textColor="#FFFFFF"
        android:backgroundTint="#388E3C"
        android:layout_marginTop="16dp"
        android:elevation="6dp" />

    <!-- Botón de procesamiento -->
    <Button
        android:id="@+id/btnProcesar"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="🌱 Procesar Plaga"
        android:textColor="#FFFFFF"
        android:backgroundTint="#43A047"
        android:layout_marginTop="16dp"
        android:elevation="6dp" />

    <!-- Vista previa -->
    <ImageView
        android:id="@+id/previewImage"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:scaleType="centerCrop"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        android:background="#1B5E20"
        android:padding="8dp"
        android:elevation="8dp" />

    <VideoView
        android:id="@+id/previewVideo"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="24dp"
        android:visibility="gone"
        android:background="#1B5E20"
        android:elevation="8dp" />

    <!-- Contenedor para fragmentos -->
    <FrameLayout
        android:id="@+id/contenedor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>
